NODE_ENV=production
PORT=3000
PUBLIC_BASE_URL=https://shipcheck.example
# Comma-separated browser origins allowed to call the API (required for split Vercel landing).
CORS_ALLOWED_ORIGINS=https://shipcheck-web.vercel.app,https://shipcheck.up.railway.app

# Operations
METRICS_BEARER_TOKEN=
VERIFICATION_ENABLED=true
BROWSER_EXECUTION_ENABLED=true

# Model (OpenAI) — GPT-5.6 family (https://developers.openai.com/api/docs/models)
#   gpt-5.6-terra  — balanced cost/quality (recommended for compile)
#   gpt-5.6-luna   — cheapest, high volume
#   gpt-5.6-sol    — flagship (alias: gpt-5.6)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
REQUIREMENT_COMPILER_MODEL=gpt-5.6-terra

# Database / evidence
DATABASE_URL=
# Optional: override SSL (auto-enabled for *.supabase.co). Use verify-full + CA in production when available.
# DATABASE_SSLMODE=require
# DATABASE_CA_CERT=
# S3-compatible evidence store (Tigris, R2, etc.). AWS_* / BUCKET_NAME also accepted.
TIGRIS_STORAGE_ENDPOINT=https://t3.storage.dev
TIGRIS_STORAGE_ACCESS_KEY_ID=
TIGRIS_STORAGE_SECRET_ACCESS_KEY=
TIGRIS_STORAGE_BUCKET=shipcheck
TIGRIS_STORAGE_REGION=auto
EVIDENCE_RETENTION_DAYS=7
REQUEST_RETENTION_DAYS=30
RECEIPT_RETENTION_DAYS=30

# OKX x402
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_BASE_URL=https://web3.okx.com
# Set false only for emergency boot; unpaid /v1/verify needs facilitator init for HTTP 402.
OKX_SYNC_FACILITATOR_ON_START=true
PAY_TO_ADDRESS=
# Use eip155:196 (X Layer mainnet) for OKX.AI marketplace listing.
# eip155:1952 is testnet only — marketplace token lookup will fail.
X402_NETWORK=eip155:196
SHIPCHECK_PRICE=$0.01

# Execution
WORKER_CONCURRENCY=2
MAX_RUN_SECONDS=90
MAX_EVIDENCE_BYTES=25000000
ALLOW_FREE_TEST_ROUTE=false
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=
