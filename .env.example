NODE_ENV=production
PORT=3000
PUBLIC_BASE_URL=https://shipcheck.example

# Operations
METRICS_BEARER_TOKEN=
VERIFICATION_ENABLED=true
BROWSER_EXECUTION_ENABLED=true

# Model (OpenAI)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
REQUIREMENT_COMPILER_MODEL=

# Database / evidence
DATABASE_URL=
# S3-compatible evidence store (Tigris, R2, etc.). AWS_* / BUCKET_NAME also accepted.
TIGRIS_STORAGE_ENDPOINT=https://t3.storage.dev
TIGRIS_STORAGE_ACCESS_KEY_ID=
TIGRIS_STORAGE_SECRET_ACCESS_KEY=
TIGRIS_STORAGE_BUCKET=shipcheck
TIGRIS_STORAGE_REGION=auto
EVIDENCE_RETENTION_DAYS=7
REQUEST_RETENTION_DAYS=30
RECEIPT_RETENTION_DAYS=30

# OKX x402
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_BASE_URL=https://web3.okx.com
PAY_TO_ADDRESS=
X402_NETWORK=eip155:1952
SHIPCHECK_PRICE=$0.01

# Execution
WORKER_CONCURRENCY=2
MAX_RUN_SECONDS=90
MAX_EVIDENCE_BYTES=25000000
ALLOW_FREE_TEST_ROUTE=false
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=
