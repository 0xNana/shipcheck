{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shipcheck.example/schemas/evidence-manifest.schema.json",
  "title": "ShipCheck Evidence Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "artifacts",
    "evidenceManifestHash"
  ],
  "properties": {
    "schemaVersion": {
      "const": "shipcheck-evidence-manifest-v1.0.0"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidenceArtifact"
      }
    },
    "evidenceManifestHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "$defs": {
    "evidenceArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "sha256",
        "contentType",
        "sizeBytes",
        "createdAt",
        "redaction"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": [
            "SCREENSHOT",
            "ELEMENT_SCREENSHOT",
            "TRACE",
            "DOM_EXCERPT",
            "ACCESSIBILITY_SNAPSHOT",
            "HTTP_RECORD",
            "NETWORK_RECORD",
            "CONSOLE_RECORD",
            "TARGET_FINGERPRINT"
          ]
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "contentType": {
          "type": "string",
          "minLength": 1
        },
        "sizeBytes": {
          "type": "integer",
          "minimum": 0
        },
        "storageUrl": {
          "type": "string",
          "format": "uri"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "redaction": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "applied"
          ],
          "properties": {
            "applied": {
              "type": "boolean"
            }
          }
        }
      }
    }
  }
}
