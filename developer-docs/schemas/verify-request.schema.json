{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shipcheck.example/schemas/verify-request.schema.json",
  "title": "ShipCheck Verify Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "brief",
    "deliveryUrl"
  ],
  "properties": {
    "brief": {
      "type": "string",
      "minLength": 10,
      "maxLength": 12000
    },
    "deliveryUrl": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://"
    },
    "mode": {
      "const": "quick",
      "default": "quick"
    },
    "maxRequirements": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20,
      "default": 12
    },
    "idempotencyKey": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128
    }
  }
}
