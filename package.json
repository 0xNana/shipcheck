{
  "name": "shipcheck",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm --recursive build",
    "build:web:vercel": "node scripts/vercel-build.mjs",
    "lint": "pnpm build && pnpm --recursive lint",
    "test": "pnpm build && pnpm --recursive test",
    "typecheck": "pnpm build && pnpm --recursive typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/node": "^24.0.14",
    "eslint": "^9.31.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vitest": "^3.2.4"
  }
}
